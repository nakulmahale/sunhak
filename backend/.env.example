# ============================================
# Project EMERGENCE — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# Google Gemini API Key (Required)
# Get yours at: https://aistudio.google.com/
GOOGLE_API_KEY=your_google_api_key_here

# LLM Model for agent reasoning
GEMINI_MODEL=gemini-2.0-flash

# Embedding model for ChromaDB
EMBEDDING_MODEL=models/text-embedding-004

# ChromaDB persistent storage path
CHROMA_DB_PATH=./chroma_data

# Server settings
HOST=0.0.0.0
PORT=8000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Debate settings
MAX_DEBATE_TURNS=30
AGGRESSION_DEADLOCK_THRESHOLD=0.9
CONSENSUS_THRESHOLD=0.3
